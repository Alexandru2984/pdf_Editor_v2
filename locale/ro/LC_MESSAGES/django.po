msgstr "Intrarea %(n)s trebuie să fie un obiect."

#: pdfeditor/forms.py:909
#, python-format
msgid "Entry %(n)s is missing field '%(k)s'."
msgstr "Intrării %(n)s îi lipsește câmpul „%(k)s”."

#: pdfeditor/password_validators.py:72
msgid ""
"This password has appeared in a public data breach. Choose a different one —"
" using it puts your account at risk."
msgstr ""
"Această parolă a apărut într-o scurgere publică de date. Alege alta — "
"folosirea ei îți pune contul în pericol."

#: pdfeditor/password_validators.py:80
msgid "Your password must not appear in known public data breaches."
msgstr "Parola ta nu trebuie să apară în scurgeri publice de date cunoscute."

