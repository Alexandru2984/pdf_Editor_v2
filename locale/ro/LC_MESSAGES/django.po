msgid "Your sign-in attempt expired. Please log in again."
msgstr ""
"Încercarea de autentificare a expirat. Te rugăm să te autentifici din nou."

#: pdfeditor/views/mfa.py:98
msgid "Invalid code. Try again or use a backup code."
msgstr "Cod invalid. Încearcă din nou sau folosește un cod de rezervă."

#: pdfeditor/views/mfa.py:109
msgid "Two-factor authentication is already enabled."
msgstr "Autentificarea în doi pași este deja activată."

#: pdfeditor/views/mfa.py:121
msgid "That code didn't match. Check your device's clock and try again."
msgstr ""
"Codul nu s-a potrivit. Verifică ceasul dispozitivului și încearcă din nou."

#: pdfeditor/views/mfa.py:138
msgid "Password incorrect — two-factor authentication was not disabled."
msgstr "Parolă incorectă — autentificarea în doi pași nu a fost dezactivată."

#: pdfeditor/views/mfa.py:141
msgid "Two-factor authentication disabled."
msgstr "Autentificarea în doi pași a fost dezactivată."

#: pdfeditor/views/mfa.py:152
msgid "Enable two-factor authentication first."
msgstr "Activează mai întâi autentificarea în doi pași."

#: pdfeditor/views/passkeys.py:202
msgid "Passkey removed."
msgstr "Passkey-ul a fost șters."

#: pdfeditor/views/passkeys.py:204
msgid "Passkey not found."
msgstr "Passkey-ul nu a fost găsit."

#: pdfeditor/views/profile.py:54
msgid "API key created. Copy the token now — it won't be shown again."
msgstr "Cheie API creată. Copiază tokenul acum — nu va mai fi afișat."

#: pdfeditor/views/profile.py:65
msgid "API key revoked."
msgstr "Cheie API revocată."

#: pdfeditor/views/sessions.py:46
msgid "Unknown browser"
msgstr "Browser necunoscut"

#: pdfeditor/views/sessions.py:58
msgid "unknown OS"
msgstr "sistem de operare necunoscut"

#: pdfeditor/views/sessions.py:108
msgid "Session not found."
msgstr "Sesiunea nu a fost găsită."

#: pdfeditor/views/sessions.py:111
msgid "Use the logout button to end your current session."
msgstr "Folosește butonul de deconectare pentru a încheia sesiunea curentă."

#: pdfeditor/views/sessions.py:115
msgid "Session revoked — that device is now signed out."
msgstr "Sesiune revocată — dispozitivul respectiv a fost deconectat."

#: pdfeditor/views/sessions.py:129
#, python-format
msgid "Signed out everywhere else (%(count)d session(s))."
msgstr ""
"Te-ai deconectat de pe toate celelalte dispozitive (%(count)d sesiuni)."

#: pdfeditor/views/share.py:27
msgid "Invalid share link request."
msgstr "Cerere de link invalidă."

#: pdfeditor/views/share.py:55
msgid "Share link created."
msgstr "Linkul de partajare a fost creat."

#: pdfeditor/views/share.py:90
msgid "Share link not found."
msgstr "Linkul de partajare nu a fost găsit."

#: pdfeditor/views/share.py:93
msgid "Share link revoked."
msgstr "Linkul de partajare a fost revocat."

#: pdfeditor/views/upload.py:78
msgid "Please select at least one PDF file."
msgstr "Te rugăm să selectezi cel puțin un fișier PDF."

#: pdfeditor/views/upload.py:91
#, python-format
msgid "Skipped \"%(name)s\" - only PDF files are accepted."
msgstr "S-a omis „%(name)s” — sunt acceptate doar fișiere PDF."

#: pdfeditor/views/upload.py:97
#, python-format
msgid "Skipped \"%(name)s\" - exceeds %(mb)d MB limit."
msgstr "S-a omis „%(name)s” — depășește limita de %(mb)d MB."

#: pdfeditor/views/upload.py:104
#, python-format
msgid "Skipped \"%(name)s\" - would exceed your %(mb)d MB storage quota."
msgstr "Sărit „%(name)s” — ar depăși cota ta de %(mb)d MB."

#: pdfeditor/views/upload.py:115
#, python-format
msgid "Skipped \"%(name)s\" - not a valid PDF file."
msgstr "S-a omis „%(name)s” — nu este un fișier PDF valid."

#: pdfeditor/views/upload.py:144
#, python-format
msgid "Skipped \"%(name)s\" - could not be parsed as a PDF."
msgstr "S-a omis „%(name)s” — nu a putut fi citit ca PDF."

#: pdfeditor/views/upload.py:151
#, python-format
msgid "Skipped \"%(name)s\" - %(pages)d pages exceeds the %(max)d-page limit."
msgstr ""
"S-a omis „%(name)s” — %(pages)d pagini depășesc limita de %(max)d pagini."

#: pdfeditor/views/upload.py:179
#, python-format
msgid "PDF \"%(name)s\" uploaded successfully! Choose an operation below."
msgstr ""
"PDF-ul „%(name)s” a fost încărcat cu succes! Alege o operațiune mai jos."

#: pdfeditor/views/upload.py:185
#, python-format
msgid "%(count)d PDFs uploaded successfully! Choose an operation below."
msgstr ""
"%(count)d PDF-uri au fost încărcate cu succes! Alege o operațiune mai jos."

#: pdfeditor/views/upload.py:189
msgid "No valid PDF files were uploaded."
msgstr "Niciun fișier PDF valid nu a fost încărcat."

#: pdfeditor/views/upload.py:201
msgid "PDF removed successfully."
msgstr "PDF-ul a fost șters cu succes."

