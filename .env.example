# Copy this to .env, fill the secrets, then `chmod 600 .env`. Each var
# defaults to a safe value when omitted unless marked REQUIRED.

# ---- Django core (REQUIRED) -------------------------------------------
SECRET_KEY=replace-me-with-a-50plus-char-random-string-please
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL=0
# Page-count cap on uploaded PDFs (default 500)
PDF_MAX_PAGES=500
# Per-owner storage quotas, in bytes (0 = unlimited)
PDF_QUOTA_ANON_BYTES=52428800
PDF_QUOTA_USER_BYTES=524288000

# ---- Postgres (REQUIRED for docker compose) ---------------------------
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-16
POSTGRES_USER=pdfeditor
POSTGRES_DB=pdfeditor
# When set, overrides the SQLite fallback used in bare-metal dev:
DATABASE_URL=postgres://pdfeditor:password@db:5432/pdfeditor

# ---- Async pipeline (Celery + Redis) ----------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_CONCURRENCY=2

# ---- AI / Chat --------------------------------------------------------
# Required for RAG chat ("Chat with PDF"). Grab one at https://groq.com.
GROQ_API_KEY=
# Optional override of the default LLM (any model id from the picker).
CHAT_GROQ_MODEL=llama-3.3-70b-versatile
# Optional: where fastembed caches the ONNX model. Persisted via volume.
FASTEMBED_CACHE_DIR=/app/data/fastembed
# Optional: Ollama fallback for non-chat AI rephrase.
OLLAMA_HOST=http://localhost:11434

# ---- Observability ----------------------------------------------------
# Sentry DSN. Get one at https://sentry.io (free tier is plenty).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# Comma-separated IPs and/or CIDRs allowed to scrape /metrics. Empty
# in prod = closed. The 172.16.0.0/12 range covers Docker compose
# default bridge networks so the bundled `prometheus` service can scrape
# the web replicas from inside the docker network.
PROMETHEUS_METRICS_ALLOW=127.0.0.1,172.16.0.0/12
# Grafana admin password — required for the bundled `grafana` service.
GRAFANA_ADMIN_PASSWORD=replace-me-with-a-strong-password

# ---- Mail (optional, for email confirmations) ------------------------
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=noreply@example.com
