# Copy this to .env, fill the secrets, then `chmod 600 .env`. Each var
# defaults to a safe value when omitted unless marked REQUIRED.

# ---- Django core (REQUIRED) -------------------------------------------
SECRET_KEY=replace-me-with-a-50plus-char-random-string-please
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL=0
# Trusted reverse proxies in front of the app. The real client IP is read as
# the Nth entry from the right of X-Forwarded-For (anti-spoofing). Used by the
# rate limiter, axes lockout and the /metrics allowlist.
#   3 = Cloudflare + host nginx + docker nginx (default, full prod stack)
#   2 = host nginx + bare uvicorn   ·   1 = docker nginx only   ·   0 = no proxy
TRUSTED_PROXY_COUNT=3
# Comma-separated origins allowed to POST cross-site (CSRF). Add
# http://localhost:8001 etc. for local dev; prod default is the site itself.
CSRF_TRUSTED_ORIGINS=https://pdf.micutu.com
# ClamAV upload scanning (optional). Bring up the `clamav` compose service,
# wait for it to be healthy, then set CLAMAV_ENABLED=1. With FAIL_OPEN=0
# uploads are rejected while clamd is unreachable (secure); 1 prefers uptime.
CLAMAV_ENABLED=0
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_FAIL_OPEN=0
# Page-count cap on uploaded PDFs (default 500)
PDF_MAX_PAGES=500
# Per-owner storage quotas, in bytes (0 = unlimited)
PDF_QUOTA_ANON_BYTES=52428800
PDF_QUOTA_USER_BYTES=524288000

# ---- Postgres (REQUIRED for docker compose) ---------------------------
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-16
POSTGRES_USER=pdfeditor
POSTGRES_DB=pdfeditor
# When set, overrides the SQLite fallback used in bare-metal dev:
DATABASE_URL=postgres://pdfeditor:password@db:5432/pdfeditor

# ---- Async pipeline (Celery + Redis) ----------------------------------
# Redis runs with --requirepass. Set a long random secret (e.g.
# `openssl rand -base64 36`). docker-compose bakes this into the broker,
# result-backend and cache URLs automatically — only override the URLs
# below if you point at an external Redis.
REDIS_PASSWORD=change-me-to-a-long-random-secret
CELERY_BROKER_URL=redis://:change-me-to-a-long-random-secret@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-to-a-long-random-secret@redis:6379/1
CELERY_CONCURRENCY=2

# ---- Cloudflare R2 output mirror (optional) ---------------------------
# When enabled, processed PDFs are mirrored to the R2 bucket and downloads
# are served as short-lived presigned URLs (bandwidth offload + durability).
# Endpoint is the per-account root WITHOUT the bucket suffix. Create the
# access key in the Cloudflare dashboard: R2 → Manage API Tokens, scoped
# Object Read & Write to this one bucket.
R2_ENABLED=0
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=pdf-editor
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Presigned URL lifetime in seconds.
R2_PRESIGN_TTL=300

# ---- AI / Chat --------------------------------------------------------
# Required for RAG chat ("Chat with PDF"). Grab one at https://groq.com.
GROQ_API_KEY=
# Optional override of the default LLM (any model id from the picker).
CHAT_GROQ_MODEL=llama-3.3-70b-versatile
# Optional: where fastembed caches the ONNX model. Persisted via volume.
FASTEMBED_CACHE_DIR=/app/data/fastembed
# Optional: Ollama fallback for non-chat AI rephrase.
OLLAMA_HOST=http://localhost:11434

# ---- Observability ----------------------------------------------------
# Sentry DSN. Get one at https://sentry.io (free tier is plenty).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# Comma-separated IPs and/or CIDRs allowed to scrape /metrics. Empty
# in prod = closed. The 172.16.0.0/12 range covers Docker compose
# default bridge networks so the bundled `prometheus` service can scrape
# the web replicas from inside the docker network.
PROMETHEUS_METRICS_ALLOW=127.0.0.1,172.16.0.0/12
# Grafana admin password — required for the bundled `grafana` service.
GRAFANA_ADMIN_PASSWORD=replace-me-with-a-strong-password
# Where alerts go. Leave empty to disable email notifications (alerts
# will still fire and show in the Grafana UI). Uses the same SMTP_*
# credentials as the app — no separate relay needed.
ALERT_EMAIL=
# Set to "false" to suppress Grafana's SMTP probe at boot (useful when
# the relay is intentionally offline in dev).
GRAFANA_SMTP_ENABLED=true

# ---- Mail (optional, for email confirmations) ------------------------
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=noreply@example.com
